<resources>
    <style name="Theme.GastoClaro" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.GastoClaro.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#101513</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.GastoClaro</item>
    </style>
</resources>
